# Относительно папки prisma/ (где schema.prisma)
DATABASE_URL="file:./dev.db"

# Именно ADMIN_LOGIN (не ADMIN_USERNAME)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me

# Для QR, ссылок партнёров и OG — всегда боевой Vercel (не localhost)
BASE_URL="https://econext-landing.vercel.app"
PRODUCTION_URL="https://econext-landing.vercel.app"
APP_TIMEZONE="Europe/Moscow"

SESSION_SECRET="change-me-in-production-min-32-chars-long!!"
IP_HASH_SALT="change-me"

# Vercel: Storage → Blob → подключить к проекту (иначе правки в админке не сохраняются между перезапусками)
# BLOB_READ_WRITE_TOKEN=

UPLOAD_MAX_SIZE_MB=50
